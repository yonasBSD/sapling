load("//fbpkg:fbpkg.bzl", "fbpkg")

oncall("scm_server_treehugger")

fbpkg.builder(
    name = "scm.scsc",
    buck_opts = fbpkg.buck_opts(
        mode = "opt",
    ),
    expire_days = 3,
    fail_on_redundant_configerator_fbpkg = False,
    path_actions = {
        "scsc": "fbcode//eden/mononoke/clients/scsc:scsc",
    },
)
